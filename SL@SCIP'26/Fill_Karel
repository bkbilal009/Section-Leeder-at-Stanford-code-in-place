
from karel.stanfordkarel import *

"""
Karel should fill the whole world with beepers using a serpentine pattern.
"""


def main():
    while left_is_clear():
        finish_one_row()
        move_to_next_row()
    laying_tiles()



def move_to_next_row():
    turn_right()
    move()
    turn_right()



def finish_one_row():
    laying_tiles()
    turn_around()
    move_to_wall()



def laying_tiles():
    while front_is_clear():
        put_beeper()
        move()
    put_beeper()



def turn_around():
    turn_left()
    turn_left()


def turn_right():
    turn_left()
    turn_left()
    turn_left()


def move_to_wall():
    while front_is_clear():
        move()



if __name__ == '__main__':
    main()
